{
  "name": "vocabulary-helper",
  "displayName": "Vocabulary Helper",
  "version": "1.0.0",
  "description": "A reading assistant with StarDict dictionary support.",
  "author": "Lance Mei",
  "scripts": {
    "dev": "plasmo dev --target=firefox-mv2",
    "build": "plasmo build --target=firefox-mv2",
    "build:chrome": "plasmo build",
    "package": "plasmo package",
    "test": "vitest run"
  },
  "dependencies": {
    "dexie": "^4.4.2",
    "lru-cache": "^11.3.5",
    "plasmo": "0.90.5",
    "svelte": "4.2.9",
    "svelte-preprocess": "5.1.3"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "prettier": "3.2.4",
    "typescript": "5.3.3",
    "vitest": "^4.1.4"
  },
  "manifest": {
    "host_permissions": [
      "https://*/*"
    ],
    "permissions": [
      "storage",
      "unlimitedStorage"
    ],
    "browser_specific_settings": {
      "gecko": {
        "id": "reading-helper@example.com"
      }
    }
  }
}
